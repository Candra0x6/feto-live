# ── Backend Environment Variables (copy to .env) ──

# Server
PORT=3001
NODE_ENV=development

# Supabase PostgreSQL (via connection pooling)
# Get these from https://supabase.com/dashboard/project/<PROJECT_ID>/settings/database
DATABASE_URL="postgresql://postgres.<PROJECT>:<PASSWORD>@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<PROJECT>:<PASSWORD>@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Redis (optional — falls back to in-memory cache)
REDIS_URL=""

# TxLINE API
TXLINE_API_URL="https://txline-dev.txodds.com"
TXLINE_WS_URL="wss://txline-dev.txodds.com/ws/scores"
TXLINE_API_KEY=""

# Solana
SOLANA_RPC_URL="https://api.devnet.solana.com"
PROGRAM_FACTORY_ID="8FRnebXM2T3xcvuPpirKRuPZVGPzXpyx1kEVGrkTg2D4"
PROGRAM_ESCROW_ID="ey3nM2h4qjMvs33F3nn5WfrEr8f8PAgbkkqyPtwgEGz"
PROGRAM_SETTLE_ID="DmRQTT8rJSSxNNjDiXwSMjzotP2xwdfngBnqtggRsPGz"

# JWT (change in production!)
JWT_SECRET="change-me-to-a-random-64-char-string"

# Sentry (error monitoring — get DSN from https://sentry.io)
SENTRY_DSN=""

# ── Keeper Bot ──
# Generate with: npx tsx src/keeper/setup-keypair.ts
KEEPER_PRIVATE_KEY=""
KEEPER_DEMO_MODE=false
KEEPER_POLL_INTERVAL=5000
KEEPER_MAX_RETRIES=3
KEEPER_RETRY_DELAY=2000
KEEPER_HEALTH_PORT=9090
KEEPER_REST_POLL=false
